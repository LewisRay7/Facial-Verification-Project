EXAMVERIFY_ENV=development
JWT_SECRET=replace-with-a-long-random-secret
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_EMAIL=you@example.com
SUPER_ADMIN_PASSWORD=Admin@12345

# Local-only SMTP fallback. Render Free should use RESEND_* instead.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Production OTP on Render Free through HTTPS email API.
RESEND_API_KEY=
RESEND_FROM=ExamVerify <onboarding@resend.dev>

# Optional external database.
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME
